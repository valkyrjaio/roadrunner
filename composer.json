{
  "name"              : "valkyrja/roadrunner",
  "type"              : "library",
  "description"       : "RoadRunner persistent worker entry point for the Valkyrja Framework.",
  "homepage"          : "https://www.valkyrja.io",
  "keywords"          : [
    "framework",
    "valkyrja",
    "roadrunner",
    "worker"
  ],
  "license"           : "MIT",
  "authors"           : [
    {
      "name"  : "Melech Mizrachi",
      "email" : "melechmizrachi@gmail.com"
    }
  ],
  "require"           : {
    "php"                      : ">=8.4",
    "spiral/roadrunner-http"   : "^4.1.0",
    "valkyrja/valkyrja"        : "^26.1.0"
  },
  "conflict"          : {
    "spiral/roadrunner-http" : "<4.1.0"
  },
  "autoload"          : {
    "psr-4" : {
      "Valkyrja\\RoadRunner\\" : "src/Valkyrja/RoadRunner"
    }
  },
  "minimum-stability" : "dev",
  "prefer-stable"     : true,
  "extra"             : {
    "branch-alias" : {
      "dev-master" : "26.x-dev"
    }
  }
}